# ─────────────────────────────────────────────────────────────────────────
# LLM 提供商
# ─────────────────────────────────────────────────────────────────────────

# Moonshot / Kimi（默认主模型）
MOONSHOT_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# DeepSeek（Deep Think 模式专用；工具链 LLM 默认也用它，可通过 UTILITY_LLM_* 切换）
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 火山引擎（Doubao 代码模型，代码意图路由）
ARK_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 阿里云百炼（DashScope · OpenAI 兼容端点）—— Qwen 系列，可选
# 不填则前端选 qwen3.5-flash 时调用会 401；填了即可在 ChatToolbar 切到 qwen 模型
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 工具链 LLM（意图识别 / 改写 / Condenser / Agentic RAG / Multi-Query / Solo 复杂度）
# 默认 fallback 到 DeepSeek；取消注释并填写下三行可整体切换到 Qwen（或其它 OpenAI-compatible 模型）
# UTILITY_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# UTILITY_LLM_API_KEY=sk-xxxxxxxx   # 填 DASHSCOPE_API_KEY 的值
# UTILITY_LLM_MODEL=qwen3.5-flash

# SerpApi（联网搜索）
SERPAPI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# HuggingFace 镜像（国内网络下载模型必需）
HF_ENDPOINT=https://hf-mirror.com

# ─────────────────────────────────────────────────────────────────────────
# 数据库
# ─────────────────────────────────────────────────────────────────────────

MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=chatbox

# Vector store (Qdrant)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=kb_main
QDRANT_API_KEY=
VECTOR_STORE_SEARCH_MODE=dense          # dense | hybrid；非 BGE-M3 模型自动降级为 dense
VECTOR_STORE_HYBRID_FUSION=rrf          # rrf | dbsf
VECTOR_STORE_RECALL_K=20                # 有 Reranker 时的候选数
VECTOR_STORE_TOP_K=4                    # 无 Reranker 时直接返回的数量

# ─────────────────────────────────────────────────────────────────────────
# LangSmith 可观测性（可选，默认关闭）
# ─────────────────────────────────────────────────────────────────────────
# 开启后：所有 LangChain / LangGraph 调用自动追踪；
# 7 处直连 AsyncOpenAI 的模块通过 app/services/_langsmith.py:get_openai() 包装后也追踪。
# 关闭时（默认）所有 wrap / @traceable 都零开销空转，不产生网络调用。
#
# 详细设计与 7 处手动包装位置见：
#   plan-doc-dir/集成LangSmith可观测性.md

LANGSMITH_TRACING=false                                      # true / false
LANGSMITH_API_KEY=                                           # 从 https://smith.langchain.com 申请
LANGSMITH_PROJECT=chatbox-dev                                # 项目名；建议 dev/prod 分开
LANGSMITH_ENDPOINT=https://api.smith.langchain.com           # 默认值，self-host 时改为自己的地址
